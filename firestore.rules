rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == "boyjb1208@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'contact', 'carType', 'carYear', 'location', 'status', 'createdAt']) &&
             data.keys().hasOnly(['name', 'contact', 'carType', 'carYear', 'location', 'message', 'status', 'memo', 'createdAt']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 50 &&
             data.contact is string && data.contact.size() >= 1 && data.contact.size() <= 20 &&
             data.carType is string && data.carType.size() >= 1 && data.carType.size() <= 100 &&
             data.carYear is string && data.carYear.size() >= 1 && data.carYear.size() <= 20 &&
             data.location is string && data.location.size() >= 1 && data.location.size() <= 100 &&
             (!('message' in data) || (data.message is string && data.message.size() <= 1000)) &&
             data.status in ['pending', 'contacted', 'completed'] &&
             (!('memo' in data) || (data.memo is string && data.memo.size() <= 1000)) &&
             data.createdAt is timestamp;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'category', 'createdAt']) &&
             data.keys().hasOnly(['title', 'summary', 'content', 'category', 'thumbnail', 'createdAt']) &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 200 &&
             (!('summary' in data) || (data.summary is string && data.summary.size() <= 500)) &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 10000 &&
             data.category in ['notice', 'blog'] &&
             (!('thumbnail' in data) || (data.thumbnail is string && data.thumbnail.size() <= 1000)) &&
             data.createdAt is timestamp;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['name', 'rating', 'content', 'createdAt']) &&
             data.keys().hasOnly(['name', 'rating', 'content', 'createdAt']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 50 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['heroTitle', 'heroSubtitle', 'companyName', 'address', 'phone', 'hours', 'primaryColor', 'metaTitle', 'metaDescription']) &&
             data.keys().hasOnly(['heroTitle', 'heroSubtitle', 'companyName', 'address', 'phone', 'hours', 'primaryColor', 'metaTitle', 'metaDescription']) &&
             data.heroTitle is string && data.heroTitle.size() <= 100 &&
             data.heroSubtitle is string && data.heroSubtitle.size() <= 200 &&
             data.companyName is string && data.companyName.size() <= 100 &&
             data.address is string && data.address.size() <= 200 &&
             data.phone is string && data.phone.size() <= 50 &&
             data.hours is string && data.hours.size() <= 100 &&
             data.primaryColor is string && data.primaryColor.size() <= 20 &&
             data.metaTitle is string && data.metaTitle.size() <= 100 &&
             data.metaDescription is string && data.metaDescription.size() <= 300;
    }

    // ===============================================================
    // Matches
    // ===============================================================
    match /inquiries/{inquiryId} {
      allow create: if isValidId(inquiryId) && isValidInquiry(incoming()) && incoming().status == 'pending';
      allow list: if isAdmin();
      allow get, delete: if isValidId(inquiryId) && isAdmin();
      allow update: if isValidId(inquiryId) && isAdmin() && isValidInquiry(incoming());
    }

    match /posts/{postId} {
      allow list: if true;
      allow get: if isValidId(postId);
      allow create: if isValidId(postId) && isAdmin() && isValidPost(incoming());
      allow update: if isValidId(postId) && isAdmin() && isValidPost(incoming());
      allow delete: if isValidId(postId) && isAdmin();
    }

    match /reviews/{reviewId} {
      allow list: if true;
      allow get: if isValidId(reviewId);
      allow create: if isValidId(reviewId) && isAdmin() && isValidReview(incoming());
      allow update: if isValidId(reviewId) && isAdmin() && isValidReview(incoming());
      allow delete: if isValidId(reviewId) && isAdmin();
    }

    match /settings/{settingId} {
      allow list: if true;
      allow get: if isValidId(settingId);
      // Allow initial creation by anyone if it's the global doc and doesn't exist yet
      // This is a bootstrap helper to avoid "insufficient permissions" on first load
      allow create: if isValidId(settingId) && settingId == 'global' && 
                    (!exists(/databases/$(database)/documents/settings/global) || isAdmin()) && 
                    isValidSettings(incoming());
      allow update: if isValidId(settingId) && isAdmin() && isValidSettings(incoming());
    }
  }
}
