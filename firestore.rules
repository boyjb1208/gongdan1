rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "boyjb1208@gmail.com" && request.auth.token.email_verified == true;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidInquiry() {
      return hasOnlyAllowedFields(['name', 'contact', 'carType', 'carYear', 'location', 'message', 'status', 'memo', 'createdAt']) &&
             validStringLength('name', 1, 50) &&
             validStringLength('contact', 1, 20) &&
             validStringLength('carType', 1, 100) &&
             validStringLength('carYear', 1, 20) &&
             validStringLength('location', 1, 100) &&
             (!('message' in request.resource.data) || validStringLength('message', 0, 1000)) &&
             request.resource.data.status in ['pending', 'contacted', 'completed'] &&
             (!('memo' in request.resource.data) || validStringLength('memo', 0, 1000)) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidPost() {
      return hasOnlyAllowedFields(['title', 'summary', 'content', 'category', 'thumbnail', 'createdAt']) &&
             validStringLength('title', 1, 200) &&
             (!('summary' in request.resource.data) || validStringLength('summary', 0, 500)) &&
             validStringLength('content', 1, 10000) &&
             request.resource.data.category in ['notice', 'blog'] &&
             (!('thumbnail' in request.resource.data) || validStringLength('thumbnail', 0, 1000)) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidReview() {
      return hasOnlyAllowedFields(['name', 'rating', 'content', 'createdAt']) &&
             validStringLength('name', 1, 50) &&
             request.resource.data.rating is number &&
             request.resource.data.rating >= 1 && request.resource.data.rating <= 5 &&
             validStringLength('content', 1, 1000) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidSettings() {
      return hasOnlyAllowedFields(['heroTitle', 'heroSubtitle', 'companyName', 'address', 'phone', 'hours', 'primaryColor', 'metaTitle', 'metaDescription']) &&
             validStringLength('heroTitle', 1, 100) &&
             validStringLength('heroSubtitle', 1, 200) &&
             validStringLength('companyName', 1, 100) &&
             validStringLength('address', 1, 200) &&
             validStringLength('phone', 1, 50) &&
             validStringLength('hours', 1, 100) &&
             validStringLength('primaryColor', 1, 20) &&
             validStringLength('metaTitle', 1, 100) &&
             validStringLength('metaDescription', 1, 300);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /inquiries/{inquiryId} {
      // Anyone can create an inquiry
      allow create: if isValidInquiry() && request.resource.data.status == 'pending';
      // Only admin can read, update, delete
      allow read, delete: if isAdmin();
      allow update: if isAdmin() && isValidInquiry();
    }

    match /posts/{postId} {
      // Anyone can read posts
      allow read: if true;
      // Only admin can create, update, delete
      allow create: if isAdmin() && isValidPost();
      allow update: if isAdmin() && isValidPost();
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;
      // Only admin can create, update, delete
      allow create: if isAdmin() && isValidReview();
      allow update: if isAdmin() && isValidReview();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      // Anyone can read settings
      allow read: if true;
      // Only admin can create, update
      allow create: if isAdmin() && isValidSettings();
      allow update: if isAdmin() && isValidSettings();
      allow delete: if false; // Settings shouldn't be deleted
    }
  }
}
